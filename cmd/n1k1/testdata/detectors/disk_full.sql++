-- label: ET-12345
-- severity: high
-- source: logs
-- versions: ["7.2","7.6"]
-- tags: ["disk","io"]
-- A disk-full error detector: a fusable single-keyspace predicate that the corpus
-- compiler folds into the shared scan and the predicate index prunes on "ERROR".
SELECT l.msg, l.ts FROM logs l WHERE l.sev = "ERROR"
-- @fixture
{"sev":"ERROR","msg":"disk full","ts":3}
{"sev":"WARN","msg":"ok","ts":5}
{"sev":"ERROR","msg":"oom","ts":9}
-- @expect
{"tag":"ET-12345","evidence":{"msg":"disk full","sev":"ERROR","ts":3}}
{"tag":"ET-12345","evidence":{"msg":"oom","sev":"ERROR","ts":9}}
