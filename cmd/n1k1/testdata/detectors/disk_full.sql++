-- label: ET-12345
-- description: disk-full errors
-- source: logs
-- tags: ["disk","io"]
-- A disk-full error query: a fusable single-keyspace predicate that the corpus
-- compiler folds into the shared scan and the predicate index prunes on "ERROR".
SELECT l.msg, l.ts FROM logs l WHERE l.sev = "ERROR"
